[manifest]
version = "1.0.0"
priority = 0

[[patches]]
[patches.pattern]
target = "functions/misc_functions.lua"
pattern = "function localize(args, misc_cat)"
position = "after"
payload = '''
  sendInfoMessage('HERE')
  if (type(args) == 'table') then
    sendInfoMessage(inspect(args))
  else
    sendInfoMessage(args)
  end
  sendInfoMessage(misc_cat)
'''
match_indent = true
times = 1
